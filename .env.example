# Copy this file to .env and fill in values before running `make up`.
# Never commit .env to version control.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=api_extractor

# Async DSN used by SQLAlchemy (asyncpg driver).
# Inside Docker Compose the hostname is the service name "postgres" (container port 5432).
# The host-side port is 5433 to avoid conflicts with other local Postgres instances.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/api_extractor

# Redis
# Inside Docker Compose the hostname is the service name "redis".
REDIS_URL=redis://redis:6379/0

# Application timezone — all cron jobs use this.
TZ=America/Sao_Paulo

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
